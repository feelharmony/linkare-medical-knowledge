---
layout: null
permalink: /search.json
sitemap: false
---
{
  "entities": [
    {%- assign all_entities = site.pages | where_exp: "p", "p.entity_id" -%}
    {%- for p in all_entities -%}
    {
      "id": {{ p.entity_id | jsonify }},
      "type": {{ p.entity_type | jsonify }},
      "title": {{ p.title | jsonify }},
      "title_en": {{ p.title_en | default: "" | jsonify }},
      "description": {{ p.description | default: "" | jsonify }},
      "url": {{ p.url | relative_url | jsonify }},
      "aliases": {{ p.aliases | default: empty | jsonify }},
      "last_reviewed": {{ p.last_reviewed | default: "" | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
